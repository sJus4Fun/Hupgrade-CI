# Build configuration — single source of truth for all brand values
# 修改此文件后需重新运行: scripts/apply_branding.sh

# User-facing app name (supports Unicode)
APP_NAME="梯云纵"

# Internal executable/system name (ASCII only, no spaces).
# Used for Windows .exe, MSIX identity_name prefix, Linux package_name, etc.
# For a clean rebrand, change this to a short ASCII identifier matching YOUR brand.
APP_EXE_NAME=hiddify

# Bundle/package identifier (reverse-domain format)
BUNDLE_ID=com.tiyunzong.app

# Publisher/distributor name (displayed in MSIX, Inno Setup, About dialog)
APP_PUBLISHER="梯云纵"

# Copyright string (shown in About dialog, file metadata)
COPYRIGHT="Copyright © 2024 梯云纵. All rights reserved."

# Support links
PUBLISHER_URL=https://www.梯云纵.com
PRIVACY_URL=https://example.com/privacy
TERMS_URL=https://example.com/terms
CONTACT_EMAIL=support@tiyunzong.site

# App version override (overrides pubspec.yaml version)
APP_VERSION=1.0.0

# App build number (integer, incremented for each release)
APP_BUILD_NUMBER=1

# Custom URL scheme for deep linking (e.g., "tiyunzong" means tiyunzong:// links)
# The standard VPN protocol schemes (v2ray:// clash:// etc.) are always registered.
# Only change this if you need a custom app-specific scheme.
URL_SCHEME=hiddify

# Customer service
# Crisp website ID (from dashboard)
CHAT_WIDGET_ID=efeabc31-728d-480b-9a2d-4aab4ea36634


